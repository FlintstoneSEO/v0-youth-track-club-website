---
interface Props {
  title: string;
  eyebrow?: string;
  subtitle?: string;
  tone?: "primary" | "success" | "dark";
}

const { title, eyebrow, subtitle, tone = "primary" } = Astro.props;
const toneClass = {
  primary: "bg-primary text-primary-foreground",
  success: "bg-success text-success-foreground",
  dark: "bg-neutral-950 text-white",
}[tone];
---

<section class={`py-16 lg:py-24 ${toneClass}`}>
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      {eyebrow && <p class="mb-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold">{eyebrow}</p>}
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl" data-editable="source" data-key="hero-title">{title}</h1>
      {subtitle && <p class="mt-6 text-lg leading-relaxed opacity-80" data-editable="source" data-key="hero-subtitle">{subtitle}</p>}
    </div>
  </div>
</section>
