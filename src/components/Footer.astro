---
import { Facebook } from "lucide-astro";
import { Instagram } from "lucide-astro";
import { Mail } from "lucide-astro";
import { MapPin } from "lucide-astro";
import site from "@/data/site.json";
import footer from "@/data/footer.json";

const socialIcons: Record<string, any> = { Facebook, Instagram };
---

<footer class="bg-primary text-primary-foreground">
  <div class="container py-12 lg:py-16">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <img src="/images/latc-logo.jpg" alt="Lansing Area Track Club" class="h-14 w-auto rounded-lg bg-white p-1" />
          <div>
            <p class="text-sm font-bold leading-tight">Lansing Area</p>
            <p class="text-sm font-bold leading-tight text-accent">Track Club</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-primary-foreground/80" data-editable="text" data-type="block" data-prop="@data[footer].description">
          {footer.description}
        </p>
        <p class="text-xs leading-relaxed text-primary-foreground/70" data-editable="text" data-type="block" data-prop="@data[footer].service_area_note">
          {footer.service_area_note}
        </p>
        <div class="flex gap-4">
          {footer.social_links.map((link) => {
            const Icon = socialIcons[link.label] ?? Facebook;
            return (
              <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.label} class="text-primary-foreground/70 hover:text-accent">
                <Icon class="h-5 w-5" />
              </a>
            );
          })}
        </div>
      </div>

      <div class="contents" data-editable="array" data-prop="@data[footer].columns">
        {footer.columns.map((column) => (
          <div data-editable="array-item">
            <h2 class="mb-4 font-semibold" data-editable="text" data-prop="heading">{column.heading}</h2>
            <ul class="space-y-2" data-editable="array" data-prop="links">
              {column.links.map((link) => (
                <li data-editable="array-item">
                  <a href={link.url} class="text-sm text-primary-foreground/80 hover:text-accent" data-editable="text" data-prop="label">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div>
        <h2 class="mb-4 font-semibold">Contact Us</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <MapPin class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
            <span class="text-sm text-primary-foreground/80">Lansing, Michigan and Mid-Michigan</span>
          </li>
          <li class="flex items-center gap-3">
            <Mail class="h-5 w-5 shrink-0 text-accent" />
            <a href={`mailto:${site.email}`} class="text-sm text-primary-foreground/80 hover:text-accent">{site.email}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-primary-foreground/10 pt-8 text-center text-sm text-primary-foreground/60 sm:flex sm:items-center sm:justify-between sm:text-left">
      <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <p>Founded by {site.founder}</p>
    </div>
    <p class="mt-4 text-center text-xs text-primary-foreground/45">
      <a href={footer.credit_url} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-accent">{footer.credit}</a>
    </p>
  </div>
</footer>
