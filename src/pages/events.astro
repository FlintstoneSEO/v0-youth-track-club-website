---
import { getCollection } from "astro:content";
import { ArrowRight } from "lucide-astro";
import { Calendar } from "lucide-astro";
import { Clock } from "lucide-astro";
import { ExternalLink } from "lucide-astro";
import { MapPin } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";

const events = (await getCollection("events"))
  .filter((event) => event.data.is_published && event.data.event_date >= new Date())
  .sort((a, b) => a.data.event_date.getTime() - b.data.event_date.getTime());
const types = ["meet", "practice", "community", "fundraiser", "other"];
---

<BaseLayout title="Meets, Events & Local Races" description="Find upcoming youth track meets, Lansing running events, local races, and community race opportunities connected to Lansing Area Track Club.">
  <PageHero title="Meets & Events" subtitle="Stay up to date with track meets, competitions, and community events from Lansing Area Track Club." />
  <section class="border-b border-border py-6">
    <div class="container flex flex-wrap items-center justify-center gap-6">
      <span class="text-sm font-semibold text-muted-foreground">Event Types:</span>
      {types.map((type) => <span class="flex items-center gap-2 text-sm capitalize text-muted-foreground"><span class="h-3 w-3 rounded-full bg-primary"></span>{type}</span>)}
    </div>
  </section>
  <section class="py-16 lg:py-24">
    <div class="container max-w-4xl space-y-6">
      {events.length === 0 ? (
        <div class="py-12 text-center"><p class="text-lg text-muted-foreground">No upcoming events at this time.</p></div>
      ) : events.map((event) => (
        <article class="card overflow-hidden">
          <div class="h-1.5 bg-primary"></div>
          <div class="p-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <div class="mb-2 flex gap-2">
                  <span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold capitalize text-primary">{event.data.event_type}</span>
                  {event.data.is_featured && <span class="rounded-full bg-accent/10 px-2.5 py-1 text-xs font-semibold text-accent">Featured</span>}
                </div>
                <h2 class="text-xl font-bold">{event.data.title}</h2>
                {event.data.description && <p class="mt-2 leading-relaxed text-muted-foreground">{event.data.description}</p>}
                <div class="mt-4 flex flex-wrap gap-4 text-sm text-muted-foreground">
                  <span class="flex items-center gap-2"><Calendar class="h-4 w-4 text-primary" />{event.data.event_date.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric", year: "numeric" })}</span>
                  {event.data.start_time && <span class="flex items-center gap-2"><Clock class="h-4 w-4 text-primary" />{event.data.start_time}</span>}
                  {event.data.location && <span class="flex items-center gap-2"><MapPin class="h-4 w-4 text-primary" />{event.data.location}</span>}
                </div>
              </div>
              {event.data.registration_url && <a href={event.data.registration_url} class="btn btn-accent shrink-0" target="_blank" rel="noopener noreferrer">Register <ExternalLink class="h-4 w-4" /></a>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
  <section class="bg-muted py-12 text-center">
    <h2 class="text-2xl font-bold">Looking for Past Results?</h2>
    <p class="mt-3 text-muted-foreground">Check our announcements page for meet results and athlete highlights.</p>
    <a href="/announcements/" class="btn btn-outline mt-6">View Announcements <ArrowRight class="h-4 w-4" /></a>
  </section>
  <section class="py-16 text-center lg:py-24">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Want to Compete with LATC?</h2>
    <p class="mt-4 text-lg text-muted-foreground">Register your athlete today to participate in our meets and events.</p>
    <a href="/contact/" class="btn btn-primary mt-10">Join the Team <ArrowRight class="h-4 w-4" /></a>
  </section>
</BaseLayout>
