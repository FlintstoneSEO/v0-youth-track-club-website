---
import { getCollection, render } from "astro:content";
import { Calendar } from "lucide-astro";
import { Megaphone } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";

const announcements = (await getCollection("announcements"))
  .filter((item) => item.data.is_published)
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime());
const renderedAnnouncements = await Promise.all(
  announcements.map(async (item) => {
    const { Content } = await render(item);
    return { item, Content };
  }),
);
const urgent = renderedAnnouncements.filter(({ item }) => item.data.priority === "urgent");
const regular = renderedAnnouncements.filter(({ item }) => item.data.priority !== "urgent");
---

<BaseLayout title="Club Announcements & Updates" description="Stay updated with Lansing Area Track Club news, practice updates, registration reminders, and important information for Lansing families.">
  <PageHero title="Announcements" subtitle="Stay updated with the latest news, updates, and important information from Lansing Area Track Club." />

  {urgent.length > 0 && (
    <section class="border-b border-red-100 bg-red-50 py-8">
      <div class="container max-w-4xl space-y-4">
        {urgent.map(({ item, Content }) => (
          <article class="card border-red-200 bg-white p-6">
            <div class="mb-2 flex items-center gap-2 text-sm font-semibold text-red-600">
              <Megaphone class="h-5 w-5" />
              Urgent
            </div>
            <h2 class="text-xl font-bold">{item.data.title}</h2>
            <p class="mt-2 flex items-center gap-2 text-sm text-muted-foreground">
              <Calendar class="h-4 w-4" />
              {item.data.published_at.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
            </p>
            <div class="mt-4 leading-relaxed text-muted-foreground">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="py-16 lg:py-24">
    <div class="container max-w-4xl space-y-6">
      {announcements.length === 0 ? (
        <div class="py-12 text-center">
          <Megaphone class="mx-auto mb-6 h-12 w-12 text-muted-foreground" />
          <h2 class="text-2xl font-bold">No Announcements Yet</h2>
          <p class="mt-3 text-muted-foreground">Check back soon for news and updates.</p>
        </div>
      ) : (
        regular.map(({ item, Content }) => (
            <article class="card p-6">
              <span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold capitalize text-primary">{item.data.priority === "normal" ? "Update" : item.data.priority}</span>
              <h2 class="mt-3 text-xl font-bold">{item.data.title}</h2>
              <p class="mt-2 flex items-center gap-2 text-sm text-muted-foreground">
                <Calendar class="h-4 w-4" />
                {item.data.published_at.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
              </p>
              <div class="mt-4 leading-relaxed text-muted-foreground">
                <Content />
              </div>
            </article>
        ))
      )}
    </div>
  </section>
</BaseLayout>
