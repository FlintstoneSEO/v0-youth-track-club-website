---
import { getCollection } from "astro:content";
import { ArrowRight } from "lucide-astro";
import { Calendar } from "lucide-astro";
import { Heart } from "lucide-astro";
import { MapPin } from "lucide-astro";
import { Target } from "lucide-astro";
import { Users } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import site from "@/data/site.json";

const today = new Date();
const events = (await getCollection("events"))
  .filter((event) => event.data.is_published && event.data.event_date >= today)
  .sort((a, b) => a.data.event_date.getTime() - b.data.event_date.getTime())
  .slice(0, 3);
const urgentAnnouncement = (await getCollection("announcements"))
  .filter((item) => item.data.is_published && item.data.priority === "urgent")
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())[0];

const features = [
  { icon: Users, title: "Youth Through High School", description: "Programs for athletes from elementary age through high school, including off-season speed and endurance training." },
  { icon: Target, title: "Proper Technique", description: "Learn correct running form, track events, discipline, and athlete development from experienced coaches." },
  { icon: Heart, title: "Community Centered", description: "More than a track club, we build confidence, character, and lasting connections in the Lansing community." },
];
---

<BaseLayout>
  {urgentAnnouncement && (
    <div class="bg-accent px-4 py-3 text-center text-accent-foreground">
      <strong>{urgentAnnouncement.data.title}</strong>
      <a href="/announcements/" class="ml-2 underline underline-offset-2">Learn more</a>
    </div>
  )}

  <section class="relative overflow-hidden bg-neutral-950 py-20 text-white lg:py-32">
    <img src="/images/latc-track-hero.png" alt="" class="hero-photo absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-neutral-950/70"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/30 via-neutral-950/35 to-neutral-950/80"></div>
    <div class="absolute inset-x-0 top-0 h-px overflow-hidden bg-white/10">
      <div class="track-sheen h-full w-1/2 bg-gradient-to-r from-transparent via-accent to-transparent"></div>
    </div>
    <div class="container relative">
      <div class="mx-auto max-w-3xl text-center">
        <img src="/images/latc-logo.jpg" alt="Lansing Area Track Club" class="rise mx-auto mb-6 w-40 rounded-xl bg-white p-2 shadow-2xl ring-1 ring-white/25 sm:w-48" />
        <p class="rise mb-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold">Serving Lansing & Mid-Michigan Since 2015</p>
        <h1 class="rise text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">Lansing Area Track Club</h1>
        <p class="mt-4 text-xl font-semibold text-accent">Youth Track & Running in Lansing, Michigan</p>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/80">
          Helping young athletes grow on and off the track. Led by Coach Ramon Brunson, we provide a positive environment where kids can build speed, endurance, confidence, discipline, and a love for running.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/contact/" class="btn btn-accent w-full sm:w-auto">Join the Track Club <ArrowRight class="h-4 w-4" /></a>
          <a href="/practices/" class="btn btn-light w-full sm:w-auto">View Practices & Meets</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-glow py-16 lg:py-20">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg leading-relaxed text-muted-foreground">
          Founded from a simple idea of getting kids together to train, Lansing Area Track Club has grown into a community-centered youth track program serving families across Lansing and Mid-Michigan.
        </p>
        <a href="/about/" class="btn mt-4 text-primary">Learn more about our story <ArrowRight class="h-4 w-4" /></a>
      </div>
    </div>
  </section>

  <section class="bg-muted py-16 lg:py-24">
    <div class="container">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Why Lansing Area Track Club?</h2>
        <p class="mt-4 text-lg text-muted-foreground">We are a community dedicated to developing young athletes in Lansing and Mid-Michigan.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {features.map((feature) => {
          const Icon = feature.icon;
          return (
            <article class="card motion-card p-6">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10">
                <Icon class="h-6 w-6 text-accent" />
              </div>
              <h3 class="text-xl font-bold">{feature.title}</h3>
              <p class="mt-3 leading-relaxed text-muted-foreground">{feature.description}</p>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="container">
      <div class="mb-12 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Upcoming Events</h2>
          <p class="mt-2 text-muted-foreground">Stay updated with practices, meets, and community events.</p>
        </div>
        <a href="/events/" class="btn btn-outline">View All Events <ArrowRight class="h-4 w-4" /></a>
      </div>
      {events.length === 0 ? (
        <div class="rounded-xl bg-muted p-12 text-center text-muted-foreground">No upcoming events at this time. Check back soon!</div>
      ) : (
        <div class="grid gap-6 md:grid-cols-3">
          {events.map((event) => (
            <article class="card motion-card overflow-hidden">
              <div class={`h-2 ${event.data.event_type === "practice" ? "bg-primary" : event.data.event_type === "meet" ? "bg-accent" : "bg-success"}`}></div>
              <div class="p-6">
                <span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold capitalize text-primary">{event.data.event_type}</span>
                <h3 class="mt-3 text-lg font-bold">{event.data.title}</h3>
                <p class="mt-4 flex items-center gap-2 text-sm text-muted-foreground"><Calendar class="h-4 w-4" /> {event.data.event_date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</p>
                {event.data.location && <p class="mt-2 flex items-center gap-2 text-sm text-muted-foreground"><MapPin class="h-4 w-4" /> {event.data.location}</p>}
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="bg-neutral-900 py-16 text-white lg:py-24">
    <div class="container grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="mb-4 inline-flex rounded-full border border-red-500/30 bg-red-600/10 px-4 py-1.5 text-sm font-semibold text-red-300">Community Running Group</p>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Run Tha City 517</h2>
        <p class="mt-4 text-lg leading-relaxed text-white/80">A Lansing running group created to bring people together through movement, representation, and community.</p>
        <p class="mt-4 text-sm text-white/60">Started in June 2022, growing from a local conversation about Black runners in Lansing.</p>
        <a href="/run-tha-city-517/" class="btn mt-8 bg-red-600 text-white hover:bg-red-700">Join the Movement <ArrowRight class="h-4 w-4" /></a>
      </div>
      <img src="/images/run-tha-city-517-logo.png" alt="Run Tha City 517" class="mx-auto w-full max-w-sm drop-shadow-2xl" />
    </div>
  </section>

  <section class="section-glow bg-success/10 py-16 lg:py-24">
    <div class="container text-center">
      <p class="mb-4 inline-flex rounded-full bg-success/20 px-4 py-1.5 text-sm font-semibold text-success">Community Race</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Lansing Juneteenth 5K Run/Walk/Roll</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-muted-foreground">Join the community for a meaningful 3.1-mile event at Benjamin Davis Park, hosted with LATC and Run Tha City 517.</p>
      <a href="/juneteenth-5k/" class="btn btn-primary mt-8">Learn More About the 5K <ArrowRight class="h-4 w-4" /></a>
    </div>
  </section>

  <section class="bg-muted py-16 lg:py-20">
    <div class="container text-center">
      <p class="mb-4 inline-flex items-center rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary"><MapPin class="mr-2 h-4 w-4" /> Lansing Youth Track Club</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Serving Families Across Lansing and Mid-Michigan</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">LATC welcomes youth athletes from Lansing and nearby communities.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {site.area_served.map((area) => <span class="rounded-full border border-border bg-card px-3 py-1 text-sm font-semibold shadow-sm">{area}</span>)}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="container text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to Start Your Track Journey?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">Join the growing community of young athletes discovering their passion for track and field.</p>
      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
        <a href="/contact/" class="btn btn-accent">Register Your Athlete <ArrowRight class="h-4 w-4" /></a>
        <a href="/faq/" class="btn btn-outline">Have Questions?</a>
      </div>
    </div>
  </section>
</BaseLayout>
