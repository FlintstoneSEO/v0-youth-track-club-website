---
import { getCollection } from "astro:content";
import { ArrowRight } from "lucide-astro";
import { HelpCircle } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";

const labels: Record<string, string> = { general: "General", registration: "Registration", practices: "Practices", meets: "Competitions", equipment: "Equipment", other: "Other" };
const faqs = (await getCollection("faqs")).filter((faq) => faq.data.is_published).sort((a, b) => a.data.sort_order - b.data.sort_order);
const categories = [...new Set(faqs.map((faq) => faq.data.category))];
---

<BaseLayout title="Youth Track FAQ" description="Answers to common questions about Lansing Area Track Club registration, youth track practices, meets, equipment, and age groups.">
  <PageHero title="Frequently Asked Questions" subtitle="Find answers to common questions about Lansing Area Track Club, our programs, registration, and more." />
  <section class="py-16 lg:py-24">
    <div class="container max-w-3xl">
      {faqs.length === 0 ? <div class="py-12 text-center"><HelpCircle class="mx-auto mb-6 h-12 w-12 text-muted-foreground" /><h2 class="text-2xl font-bold">No FAQs Yet</h2></div> : categories.map((category) => <div class="mb-12"><h2 class="mb-6 text-2xl font-bold">{labels[category]}</h2><div class="space-y-4">{faqs.filter((faq) => faq.data.category === category).map((faq) => <details class="card p-5"><summary class="cursor-pointer font-bold">{faq.data.question}</summary><p class="mt-4 leading-relaxed text-muted-foreground">{faq.data.answer}</p></details>)}</div></div>)}
    </div>
  </section>
  <section class="bg-muted py-16 text-center lg:py-24"><div class="container max-w-3xl"><h2 class="text-3xl font-bold sm:text-4xl">Still Have Questions?</h2><p class="mt-4 text-lg text-muted-foreground">Reach out and we will get back to you as soon as possible.</p><a href="/contact/" class="btn btn-primary mt-10">Contact Us <ArrowRight class="h-4 w-4" /></a></div></section>
</BaseLayout>
