---
import { CheckCircle } from "lucide-astro";
import { Mail } from "lucide-astro";
import { MapPin } from "lucide-astro";
import { Send } from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import site from "@/data/site.json";
---

<BaseLayout title="Contact & Sign Up" description="Register your athlete for Lansing Area Track Club or get in touch with questions about programs.">
  <PageHero title="Contact & Sign Up" subtitle="Register your athlete for Lansing Area Track Club or get in touch with questions about our programs." />
  <section class="py-16 lg:py-24">
    <div class="container grid gap-12 lg:grid-cols-2">
      <article class="card h-fit p-6">
        <h2 class="text-2xl font-bold">Athlete Registration</h2>
        <p class="mt-2 text-muted-foreground">This static Astro form is ready to connect to your preferred provider. Replace the action URL with CloudCannon Forms, Formspree, Netlify Forms, or another endpoint.</p>
        <form method="post" action="https://example.com/replace-with-athlete-registration-endpoint" class="mt-6 space-y-4">
          <div class="grid gap-4 sm:grid-cols-2"><label> Athlete First Name *<input name="athlete_first_name" required class="mt-1 w-full rounded-md border border-border p-3" /></label><label> Athlete Last Name *<input name="athlete_last_name" required class="mt-1 w-full rounded-md border border-border p-3" /></label></div>
          <div class="grid gap-4 sm:grid-cols-2"><label> Date of Birth *<input name="athlete_dob" type="date" required class="mt-1 w-full rounded-md border border-border p-3" /></label><label> Grade Level<input name="athlete_grade" class="mt-1 w-full rounded-md border border-border p-3" /></label></div>
          <div class="grid gap-4 sm:grid-cols-2"><label> Parent First Name *<input name="parent_first_name" required class="mt-1 w-full rounded-md border border-border p-3" /></label><label> Parent Last Name *<input name="parent_last_name" required class="mt-1 w-full rounded-md border border-border p-3" /></label></div>
          <div class="grid gap-4 sm:grid-cols-2"><label> Parent Email *<input name="parent_email" type="email" required class="mt-1 w-full rounded-md border border-border p-3" /></label><label> Parent Phone *<input name="parent_phone" type="tel" required class="mt-1 w-full rounded-md border border-border p-3" /></label></div>
          <label class="block">Events of Interest<textarea name="preferred_events" rows="3" class="mt-1 w-full rounded-md border border-border p-3"></textarea></label>
          <label class="block">Medical Conditions/Allergies<textarea name="medical_conditions" rows="3" class="mt-1 w-full rounded-md border border-border p-3"></textarea></label>
          <button class="btn btn-accent w-full" type="submit">Submit Registration <Send class="h-4 w-4" /></button>
        </form>
      </article>
      <div class="space-y-8">
        <article class="card p-6">
          <h2 class="text-2xl font-bold">Get in Touch</h2>
          <p class="mt-2 text-muted-foreground">Have questions? Send us a message and we will get back to you soon.</p>
          <form method="post" action="https://example.com/replace-with-contact-endpoint" class="mt-6 space-y-4">
            <label class="block">Name<input name="name" required class="mt-1 w-full rounded-md border border-border p-3" /></label>
            <label class="block">Email<input name="email" type="email" required class="mt-1 w-full rounded-md border border-border p-3" /></label>
            <label class="block">Subject<select name="subject" class="mt-1 w-full rounded-md border border-border p-3"><option>General Question</option><option>Registration Help</option><option>Volunteering</option><option>Sponsorship</option><option>Other</option></select></label>
            <label class="block">Message<textarea name="message" required rows="4" class="mt-1 w-full rounded-md border border-border p-3"></textarea></label>
            <button class="btn btn-primary w-full" type="submit">Send Message <Send class="h-4 w-4" /></button>
          </form>
        </article>
        <article class="card p-6"><h2 class="text-xl font-bold">Contact Information</h2><div class="mt-4 space-y-4"><p class="flex gap-3"><MapPin class="h-5 w-5 text-primary" /><span><strong>Location</strong><br />Lansing, Michigan</span></p><p class="flex gap-3"><Mail class="h-5 w-5 text-primary" /><span><strong>Email</strong><br /><a href={`mailto:${site.email}`} class="text-primary">{site.email}</a></span></p></div></article>
        <article id="volunteer" class="card bg-primary p-6 text-primary-foreground"><CheckCircle class="mb-3 h-8 w-8 text-accent" /><h2 class="text-xl font-bold">Interested in Volunteering?</h2><p class="mt-2 text-primary-foreground/80">We are always looking for volunteer coaches, meet helpers, and community supporters.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
