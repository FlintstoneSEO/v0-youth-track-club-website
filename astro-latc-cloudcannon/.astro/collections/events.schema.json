{
  "$ref": "#/definitions/events",
  "definitions": {
    "events": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "event_date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "start_time": {
          "type": "string",
          "default": ""
        },
        "location": {
          "type": "string",
          "default": ""
        },
        "event_type": {
          "type": "string",
          "enum": [
            "meet",
            "practice",
            "community",
            "fundraiser",
            "other"
          ],
          "default": "meet"
        },
        "is_featured": {
          "type": "boolean",
          "default": false
        },
        "registration_url": {
          "type": "string",
          "default": ""
        },
        "is_published": {
          "type": "boolean",
          "default": true
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "event_date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}